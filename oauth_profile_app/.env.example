# Flask/FastAPI Session Encryption Key
SECRET_KEY=a_very_long_secure_random_string_for_session_signing_12345

# GitHub OAuth Application Credentials
# Register at: GitHub Settings -> Developer Settings -> OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# Google OAuth Application Credentials
# Register at: Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Discord OAuth Application Credentials
# Register at: Discord Developer Portal -> Applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback
